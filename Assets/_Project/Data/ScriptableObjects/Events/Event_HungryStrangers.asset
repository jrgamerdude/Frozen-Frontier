  id: event_hungry_strangers
  title: Hungry Strangers
  description: Travelers ask for food and shelter.
  choices:
  - id: share_food
    label: Share supplies
    costs:
    - type: 1
      amount: 10
    outcome:
      resourceDeltas: []
      heatDelta: 0
      moraleDelta: 6
      healthDelta: 0
      resultText: Compassion lifts morale.
  - id: turn_away
    label: Turn them away
    costs: []
    outcome:
      resourceDeltas: []
      heatDelta: 0
      moraleDelta: -5
      healthDelta: 0
      resultText: The camp feels colder.
  - id: trade
    label: Trade for scrap
    costs:
    - type: 1
      amount: 6
    outcome:
      resourceDeltas:
      - type: 3
        amount: 10
      heatDelta: 0
      moraleDelta: 1
      healthDelta: 0
      resultText: A hard but fair deal.
