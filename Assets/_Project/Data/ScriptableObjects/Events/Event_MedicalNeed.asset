  m_Name: Event_MedicalNeed
  m_EditorClassIdentifier: Assembly-CSharp::FrozenFrontier.Data.EventDef
  id: event_medical_need
  title: Medical Emergency
  description: A disease risk is spreading through the shelter.
  choices:
  - id: intensive_care
    label: Use medicine stock
    costs:
    - type: 1
      amount: 8
    outcome:
      resourceDeltas: []
      heatDelta: 0
      moraleDelta: 2
      healthDelta: 4
      resultText: Treatment succeeds.
  - id: quarantine
    label: Set strict quarantine
    costs: []
    outcome:
      resourceDeltas: []
      heatDelta: 0
      moraleDelta: -3
      healthDelta: -1
      resultText: Containment works, but morale suffers.
  - id: warm_rest
    label: Prioritize warmth and rest
    costs:
    - type: 2
      amount: 4
    outcome:
      resourceDeltas: []
      heatDelta: 3
      moraleDelta: 0
      healthDelta: 2
      resultText: Recovery improves in warmer tents.
