  m_Name: Event_Wreckage
  m_EditorClassIdentifier: Assembly-CSharp::FrozenFrontier.Data.EventDef
  id: event_wreckage
  title: Wreckage Found
  description: Scouts locate a half-buried transport.
  choices:
  - id: salvage
    label: Send a salvage team
    costs: []
    outcome:
      resourceDeltas:
      - type: 3
        amount: 20
      - type: 0
        amount: 8
      heatDelta: 0
      moraleDelta: 0
      healthDelta: 0
      resultText: Useful parts recovered.
  - id: careful_salvage
    label: Bring medics too
    costs:
    - type: 1
      amount: 4
    outcome:
      resourceDeltas:
      - type: 3
        amount: 14
      heatDelta: 0
      moraleDelta: 1
      healthDelta: 2
      resultText: Safe but slower salvage.
  - id: ignore
    label: Leave it
    costs: []
    outcome:
      resourceDeltas: []
      heatDelta: 0
      moraleDelta: -1
      healthDelta: 0
      resultText: You move on.
